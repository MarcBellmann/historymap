{
  "version": 8,
  "name": "HistoryMap Base",
  "sources": {
    "ocean": {
      "type": "geojson",
      "data": "/ne_110m_ocean.geojson"
    },
    "rivers": {
      "type": "geojson",
      "data": "/ne_110m_rivers.geojson"
    },
    "lakes": {
      "type": "geojson",
      "data": "/ne_110m_lakes.geojson"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#d4c5a0"
      }
    },
    {
      "id": "ocean-fill",
      "type": "fill",
      "source": "ocean",
      "paint": {
        "fill-color": "#a0bfd0",
        "fill-opacity": 1
      }
    },
    {
      "id": "ocean-shore",
      "type": "line",
      "source": "ocean",
      "paint": {
        "line-color": "#7a9fb5",
        "line-width": 0.8,
        "line-opacity": 0.8
      }
    },
    {
      "id": "lakes-fill",
      "type": "fill",
      "source": "lakes",
      "paint": {
        "fill-color": "#a0bfd0",
        "fill-opacity": 0.9
      }
    },
    {
      "id": "rivers-line",
      "type": "line",
      "source": "rivers",
      "paint": {
        "line-color": "#7a9fb5",
        "line-width": 0.8,
        "line-opacity": 0.7
      }
    }
  ]
}
