{
  "version": 8,
  "name": "HistoryMap Base",
  "sources": {
    "osm-tiles": {
      "type": "raster",
      "tiles": [
        "https://tile.openstreetmap.org/{z}/{x}/{y}.png"
      ],
      "tileSize": 256,
      "attribution": "© OpenStreetMap contributors"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#d4c5a0"
      }
    },
    {
      "id": "base-tiles",
      "type": "raster",
      "source": "osm-tiles",
      "paint": {
        "raster-opacity": 0.5,
        "raster-saturation": -0.8,
        "raster-brightness-min": 0.3,
        "raster-contrast": 0.1
      }
    }
  ]
}
